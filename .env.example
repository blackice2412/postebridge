# Hetzner Cloud API token with DNS (zones) read/write permissions
# Create one at: https://console.hetzner.cloud/ → Security → API Tokens
HETZNER_API_KEY=

# Optional — defaults to 3847
PORT=3847

# Where login credentials are stored (default: ./data)
DATA_DIR=./data

# Self-hosted Poste.io mail server (Basic auth — admin email + password)
# Base URL without trailing slash, e.g. http://posteio.example.com
POSTE_BASE_URL=
POSTE_ADMIN_EMAIL=admin@example.com
POSTE_ADMIN_PASSWORD=

# Optional — hostname used in MX/CNAME records (defaults to mail.<your-domain>)
# POSTE_MAIL_HOST=mail.tasheeltech.sy

# Set to true only when the app is served over HTTPS (e.g. Dokploy with TLS).
# Leaving this unset keeps session cookies working over plain HTTP.
# COOKIE_SECURE=true

# Trust X-Forwarded-* headers from reverse proxy (default: enabled). Set false for local-only HTTP.
# TRUST_PROXY=true
